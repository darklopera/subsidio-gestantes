generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Verificacion {
  id                        String   @id @default(uuid())
  nombreCompleto            String
  tipoDocumento             String
  numeroDocumento           String
  celular                   String
  correoElectronico         String
  direccion                 String
  ciudadMunicipio           String
  fechaNacimiento           DateTime
  edadCalculada             Int
  ruralOUrbano              String
  genero                    String
  estadoGestacion           String
  nivelEstudio              String
  tieneMedioTransporte      String
  queMedioTransporte        String?
  numeroHijosMenores        Int
  numeroHijosDiscapacitados Int
  estratoSocioeconomico     Int
  ocupacion                 String
  semanasGestacion          Int
  fechaTentativaParto       DateTime
  ingresoHogar              String
  esDesplazado              String
  numeroPersonasCargo       String
  estadoCivil               String
  situacionLaboral          String
  tipoVivienda              String
  numeroPropiedades         String
  tieneDiscapacidad         String
  sisben                    String
  tieneAguaPotable          String
  violenciaIntrafamiliar    String
  fueExcluida               Boolean
  razonExclusion            String?
  puntajeTotal              Int?
  esElegible                Boolean?
  createdAt                 DateTime @default(now())

  @@map("verificaciones")
}
